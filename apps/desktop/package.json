{
  "name": "pi-desktop",
  "version": "0.1.0",
  "description": "Desktop agent built on the pi harness — Anthropic-inspired warm UI",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "author": "hbw",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "lint": "biome check .",
    "format": "biome check --write .",
    "package": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "file:../../packages/agent",
    "@earendil-works/pi-ai": "file:../../packages/ai",
    "@earendil-works/pi-coding-agent": "file:../../packages/coding-agent",
    "@earendil-works/pi-tui": "file:../../packages/tui",
    "undici": "8.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@fontsource-variable/fraunces": "^5.1.0",
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/jetbrains-mono": "^5.1.0",
    "@types/node": "^22.19.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "katex": "^0.16.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
